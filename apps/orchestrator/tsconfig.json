{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@po-sim/shared": ["../../packages/shared/src"],
      "@po-sim/shared/*": ["../../packages/shared/src/*"],
      "@po-sim/db": ["../../packages/db/src"],
      "@po-sim/db/*": ["../../packages/db/src/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/db" }
  ]
}